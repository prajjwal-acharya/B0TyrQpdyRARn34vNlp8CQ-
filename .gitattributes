# Normalize line endings to LF for all text files
* text=auto eol=lf

# Shell scripts must always be LF even on Windows
*.sh text eol=lf

# Windows-specific scripts — keep CRLF only on Windows checkout
*.ps1 text eol=crlf

# Explicitly declare text files
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.conf text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files — do not attempt line ending conversion
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tiff binary
*.zip binary
*.gz binary
*.tar binary

# =============================================================================
# Adaptive AI Document Intelligence Platform — Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit .env with real credentials.
# =============================================================================

# --- APIs -------------------------------------------------------------------

# Google Gemini (extraction + embeddings)
GEMINI_API_KEY=

# Groq (Llama3 routing)
GROQ_API_KEY=

# LangSmith (observability / tracing)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=adaptive-doc-intel

# --- PostgreSQL -------------------------------------------------------------

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=docstore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Redis ------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# --- MinIO (object storage for raw documents) --------------------------------

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# --- ChromaDB (vector store) -------------------------------------------------

CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- Label Studio (HITL review) ----------------------------------------------

LABEL_STUDIO_URL=http://label-studio:8080
LABEL_STUDIO_TOKEN=

# --- Confidence Engine Weights -----------------------------------------------
# These defaults can be overridden per doc type in the YAML schema files.

DEFAULT_OCR_WEIGHT=0.30
DEFAULT_SCHEMA_WEIGHT=0.25
DEFAULT_CROSS_FIELD_WEIGHT=0.20
DEFAULT_RETRIEVAL_WEIGHT=0.15
DEFAULT_VERIFICATION_WEIGHT=0.10

# --- Application -------------------------------------------------------------

LOG_LEVEL=INFO
ENVIRONMENT=development
